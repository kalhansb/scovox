<?xml version="1.0" encoding="UTF-8" ?>
<!--
Cyclone DDS configuration for the laptop <-> JetBot SceneNet experiment.

WiFi multicast is unreliable, so this pins discovery to a unicast peer list
(laptop + Jetson) and disables multicast outright.

Usage: on BOTH machines, before launching anything:
  export ROS_DOMAIN_ID=42
  export RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
  export CYCLONEDDS_URI=file:///path/to/cyclonedds.xml
-->
<CycloneDDS xmlns="https://cdds.io/config"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">
  <Domain id="any">
    <General>
      <Interfaces>
        <NetworkInterface autodetermine="true"/>
      </Interfaces>
      <AllowMulticast>false</AllowMulticast>
      <FragmentSize>1280B</FragmentSize>
    </General>
    <Discovery>
      <ParticipantIndex>auto</ParticipantIndex>
      <Peers>
        <!-- Laptop's WiFi IP (wlp114s0). -->
        <Peer address="192.168.1.16"/>
        <!-- Jetson's WiFi IP (nano-4gb-jp45). -->
        <Peer address="192.168.1.22"/>
      </Peers>
    </Discovery>
    <Tracing>
      <Verbosity>warning</Verbosity>
      <OutputFile>stderr</OutputFile>
    </Tracing>
  </Domain>
</CycloneDDS>
