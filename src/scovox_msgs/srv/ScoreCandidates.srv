# Score candidate viewpoints via FOV raycasting on the fused 3D grid.
# The mapping node performs all raycasting in-process — no voxel data
# crosses the wire.

scovox_msgs/CandidatePose[] candidates
string scoring_mode          # "eig", "entropy", "frontier", "random"

# FOV configuration for raycasting
float32 fov_hfov             # Horizontal FOV (radians)
float32 fov_vfov             # Vertical FOV (radians)
float32 fov_max_range        # Maximum sensor range (m)
int32   fov_h_rays           # Horizontal ray samples
int32   fov_v_rays           # Vertical ray samples
float32 fov_occ_stop         # Stop ray at voxels above this p_occ

# Bounding box for map stats computation (same as ROI)
geometry_msgs/Point min_corner
geometry_msgs/Point max_corner
---
# One score per input candidate (same order)
float32[] scores

# Aggregate map statistics for logging
scovox_msgs/MapStats stats
