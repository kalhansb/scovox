# Keep the Docker build context small. The image only needs src/ (and only the
# package.xml manifests at build time); everything below is host-side clutter or
# colcon output that must never leak into the image.
build/
install/
log/
**/build/
**/install/
**/log/

.git/
.vscode/
.idea/
docs/

**/__pycache__/
*.pyc
*.pyo
*.egg-info/

# Eval artifacts / data (regenerated by scripts).
**/results/
**/data/
**/*.npz
**/*.npz.*
**/*.ply
**/*.bag
**/*.bag.*
**/*.mcap
**/*.log
scovox_paper/

.DS_Store
*.swp
